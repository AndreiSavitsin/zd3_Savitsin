<Window x:Class="zd3_Savitsin_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd3_Savitsin_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel x:Name="panel1" HorizontalAlignment="Center" Height="120" Margin="0,19,0,0" VerticalAlignment="Top" Width="216" Visibility="Visible">
            <TextBox x:Name="txtName" ToolTip="Введите название дороги" Height="23"/>
            <TextBox x:Name="txtWidth" ToolTip="Введите ширину дороги" Height="23"/>
            <TextBox x:Name="txtLength" ToolTip="Введите длину дороги" Height="23"/>
            <TextBox x:Name="txtWeight" ToolTip="Введите массу дорожного покрытия (на 1 кв. м.)" Height="23"/>
            <TextBox x:Name="txtSurface" ToolTip="Введите вид дорожного покрытия" Height="23"/>
        </StackPanel>
        <StackPanel x:Name="panel2" HorizontalAlignment="Center" Height="59" Margin="0,141,0,0" VerticalAlignment="Top" Width="215" Visibility="Hidden">
            <Button Content="Добавить" Foreground="White" Click="Add_Click" Background="Green"/>
            <Button Content="Вычислить массу" Foreground="White" Click="Calculate_Click" Background="Green"/>
            <Button Content="Удалить" Foreground="White" Click="Delete_Click" Background="Red"/>
        </StackPanel>
        <StackPanel x:Name="panel3" HorizontalAlignment="Left" Height="93" Margin="100,280,0,0" VerticalAlignment="Top" Width="515" Visibility="Visible">
            <ListBox x:Name="listBox" Height="85"/>
        </StackPanel>
        <StackPanel x:Name="panel4" HorizontalAlignment="Center" Height="134" Margin="0,139,0,0" VerticalAlignment="Top" Width="215" Visibility="Hidden">
            <TextBox x:Name="txtFactor" ToolTip="Введите коэффициент прочности" Height="23"/>
            <TextBox x:Name="txtWeather" ToolTip="Введите погодные условия" Height="23"/>
            <TextBox x:Name="txtCountDays" ToolTip="Введите количество дней до окончания работы" Height="23"/>
            <Button Content="Добавить" Foreground="White" Click="Add2_Click" Background="Green"/>
            <Button Content="Вычислить массу" Foreground="White" Click="Calculate2_Click" Background="Green"/>
            <Button Content="Удалить" Foreground="White" Click="Delete2_Click" Background="Red"/>
        </StackPanel>

        <Menu HorizontalAlignment="Left" Height="70" Margin="10,10,0,0" VerticalAlignment="Top" Width="190">
            <MenuItem Header="Добавить срочную дорожную работу" Click="Quickly_Click"></MenuItem>
            <MenuItem Header="Добавить несрочную дорожную работу" Click="Unquickly_Click"></MenuItem>
            <MenuItem Header="Выход" Click="Exit_Click"></MenuItem>
        </Menu>

    </Grid>
</Window>
